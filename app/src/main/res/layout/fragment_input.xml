<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_green"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cek Gizi"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prediksi kategori nutrisi makanan kemasan"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="4dp"
            android:alpha="0.9" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="80dp">

            <!-- Input Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Title -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Masukkan Data Nutrisi"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="20dp" />

                    <!-- Food Name Input (di luar GridLayout) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_food_name"
                        style="@style/TextInputLayoutStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Nama Makanan/Minuman"
                        app:boxStrokeColor="@color/primary_green"
                        app:hintTextColor="@color/primary_green">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_food_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:fontFamily="@font/poppins_regular" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Input Fields Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4"
                        android:alignmentMode="alignBounds"
                        android:columnOrderPreserved="false">

                        <!-- Energy Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_energy"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Energy (kcal)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_energy"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Protein Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_protein"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Protein (g)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_protein"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Carbo Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_carbo"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Carbo (g)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_carbo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Fat Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_fat"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Fat (g)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fat"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Sugar Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_sugar"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Sugar (g)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_sugar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Sodium Input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_sodium"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="12dp"
                            android:hint="Sodium (mg)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_sodium"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Fiber Input (Full Width) -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_fiber"
                            style="@style/TextInputLayoutStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="2"
                            android:layout_columnSpan="2"
                            android:hint="Fiber (g)"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fiber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/poppins_regular" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </GridLayout>

                    <!-- Analyze Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_analyze"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Analisis Nutrisi"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="8dp"
                        app:backgroundTint="@color/primary_green"
                        app:cornerRadius="16dp"
                        app:elevation="0dp" />
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Result Card Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:id="@+id/result_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Category Title -->
                    <TextView
                        android:id="@+id/tv_cluster_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kategori"
                        android:textSize="28sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_semibold"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="12dp" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tv_result_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Deskripsi hasil analisis nutrisi makanan"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_regular"
                        android:lineSpacingMultiplier="1.5"
                        android:layout_marginBottom="20dp"
                        android:alpha="0.95" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/white"
                        android:alpha="0.2"
                        android:layout_marginBottom="20dp" />

                    <!-- Nutrition Breakdown Title -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rincian Nutrisi"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="16dp" />

                    <!-- Nutrition Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:useDefaultMargins="true">

                        <!-- Energy -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Energy"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:alpha="0.7"
                                android:fontFamily="@font/poppins_regular"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_result_energy"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:textSize="18sp"
                                android:textColor="@color/white"
                                android:fontFamily="@font/poppins_semibold" />
                        </LinearLayout>

                        <!-- Protein -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Protein"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:alpha="0.7"
                                android:fontFamily="@font/poppins_regular"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_result_protein"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0g"
                                android:textSize="18sp"
                                android:textColor="@color/white"
                                android:fontFamily="@font/poppins_semibold" />
                        </LinearLayout>

                        <!-- Carbo -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Carbohydrate"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:alpha="0.7"
                                android:fontFamily="@font/poppins_regular"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_result_carbo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0g"
                                android:textSize="18sp"
                                android:textColor="@color/white"
                                android:fontFamily="@font/poppins_semibold" />
                        </LinearLayout>

                        <!-- Fat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Fat"
                                android:textSize="12sp"
                                android:textColor="@color/white"
                                android:alpha="0.7"
                                android:fontFamily="@font/poppins_regular"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_result_fat"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0g"
                                android:textSize="18sp"
                                android:textColor="@color/white"
                                android:fontFamily="@font/poppins_semibold" />
                        </LinearLayout>

                    </GridLayout>
                    <!-- Save Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_history"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Simpan ke Riwayat"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary_green"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />


                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
